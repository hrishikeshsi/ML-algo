# =============================================================================
# EnterpriseGPT Backend — Environment Variables
# Copy this file to .env and fill in real values. NEVER commit .env.
# =============================================================================

# --- Server ---
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
LOG_LEVEL=info

# --- CORS ---
# Comma separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# --- PostgreSQL / Prisma ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/enterprisegpt?schema=public

# --- JWT Authentication ---
JWT_SECRET=change-this-to-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-to-a-different-long-random-secret-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# --- Password Hashing ---
BCRYPT_SALT_ROUNDS=12

# --- Password Reset ---
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
PASSWORD_RESET_URL=http://localhost:5173/reset-password

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# --- SMTP (used by EmailService for password reset emails) ---
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=EnterpriseGPT
SMTP_FROM_EMAIL=no-reply@enterprisegpt.local

# =============================================================================
# Purple Fabric AI Agent (Intellect Design Magic Platform)
# The backend is the ONLY component allowed to hold these credentials.
# They must never be sent to, or read by, the frontend.
# =============================================================================

# Base domain of the Purple Fabric / Magic Platform deployment (no trailing slash)
# e.g. https://api.intellectseecapps.com
PURPLE_FABRIC_ENDPOINT=https://api.intellectseecapps.com

# Tenant identifier used in GET /accesstoken/{tenant}
PURPLE_FABRIC_TENANT=idx

# Platform API key sent as the `apikey` header on every Purple Fabric request
PURPLE_FABRIC_API_KEY=magicplatform.replace-with-real-api-key

# Service account credentials used to obtain the OAuth access/refresh token
# via GET /accesstoken/{tenant} (apikey + username + password headers)
PURPLE_FABRIC_USERNAME=service.user@example.com
PURPLE_FABRIC_PASSWORD=replace-with-real-password

# Workspace context sent as `x-platform-workspaceid` header
PURPLE_FABRIC_WORKSPACE_ID=replace-with-workspace-id

# Agent/asset version identifier used when creating a conversation
PURPLE_FABRIC_ASSET_VERSION_ID=replace-with-asset-version-id

# Human readable agent name (stored in AgentConfiguration, shown in logs/health checks)
PURPLE_FABRIC_AGENT_NAME=EnterpriseGPT Agent

# API version segment used in the Purple Fabric URL path (/magicplatform/{version}/genai/...)
PURPLE_FABRIC_API_VERSION=v1

# `app` header value required by the file upload endpoint
PURPLE_FABRIC_APP=magicplatform

# Milliseconds of safety buffer subtracted from token expiry before we proactively refresh
PURPLE_FABRIC_TOKEN_REFRESH_BUFFER_MS=30000

# Request timeout (ms) for outbound Purple Fabric calls
PURPLE_FABRIC_TIMEOUT_MS=30000

# Polling interval / max attempts used while waiting for an async agent response
PURPLE_FABRIC_POLL_INTERVAL_MS=1500
PURPLE_FABRIC_POLL_MAX_ATTEMPTS=40
